# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME="Smart To-Let"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Comma-separated client URLs allowed by CORS in production. In local/dev any
# localhost origin is allowed automatically.
CLIENT_URL=http://localhost:3000

APP_LOCALE=en
APP_TIMEZONE=Asia/Dhaka

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# Database (MySQL 8)
# ----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=smart_to_let
DB_USERNAME=root
DB_PASSWORD=

# ----------------------------------------------------------------------------
# Redis (cache, OTP, rate limiting, queue, broadcasting)
# ----------------------------------------------------------------------------
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ----------------------------------------------------------------------------
# JWT auth (access + refresh)
# ----------------------------------------------------------------------------
JWT_SECRET=
JWT_ALGO=HS256
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_TTL=2592000       # 30 days (seconds)
JWT_REFRESH_COOKIE=stl_refresh_token
JWT_REFRESH_COOKIE_SECURE=false   # set true in production (HTTPS)
JWT_REFRESH_COOKIE_SAMESITE=lax

# ----------------------------------------------------------------------------
# OTP
# ----------------------------------------------------------------------------
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ----------------------------------------------------------------------------
# SMS provider (mock | bulksmsbd)
# ----------------------------------------------------------------------------
SMS_PROVIDER=mock
SMS_SENDER_ID=SmartToLet
SMS_API_KEY=

# ----------------------------------------------------------------------------
# Cloudinary (file storage) — falls back to local "public" disk if unset
# ----------------------------------------------------------------------------
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=
FILESYSTEM_DISK=local

# ----------------------------------------------------------------------------
# Google Maps
# ----------------------------------------------------------------------------
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_BROWSER_KEY=
GEO_NEARBY_RADIUS=1500
GEO_LISTING_RADIUS_KM=5

# ----------------------------------------------------------------------------
# Broadcasting (Laravel Reverb)
# ----------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=smart-to-let
REVERB_APP_KEY=stl-local-key
REVERB_APP_SECRET=stl-local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# ----------------------------------------------------------------------------
# Payment gateways (sandbox by default)
# ----------------------------------------------------------------------------
PAYMENT_GATEWAY=bkash

BKASH_MODE=sandbox
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

NAGAD_MODE=sandbox
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_KEY=

ROCKET_MODE=sandbox
ROCKET_MERCHANT_ID=
ROCKET_API_KEY=

# ----------------------------------------------------------------------------
# Super-admin seed credentials (used once by SuperAdminSeeder)
# ----------------------------------------------------------------------------
SUPER_ADMIN_MOBILE=01700000000
SUPER_ADMIN_EMAIL=admin@smarttolet.test
SUPER_ADMIN_PASSWORD=ChangeMe!2026
SUPER_ADMIN_NAME="Super Admin"

# ----------------------------------------------------------------------------
# L5-Swagger
# ----------------------------------------------------------------------------
L5_SWAGGER_CONST_HOST="${APP_URL}/api/v1"
L5_SWAGGER_GENERATE_ALWAYS=true
